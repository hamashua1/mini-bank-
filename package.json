{
  "name": "mini-bank-",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "dev:pg": "cross-env DB_TYPE=postgres nodemon --exec ts-node src/app.ts",
    "dev:mysql": "cross-env DB_TYPE=mysql nodemon --exec ts-node src/app.ts",
    "dev:mongo": "cross-env DB_TYPE=mongo nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "tunnel": "ts-node src/tunnel.ts",
    "tunnel:db": "ts-node src/tunnel-db.ts",
    "tunnel:postgres": "ts-node src/tunnel-db.ts postgres",
    "tunnel:mysql": "ts-node src/tunnel-db.ts mysql",
    "db:migrate:postgres": "prisma migrate dev --schema=prisma/schema.postgres.prisma",
    "db:migrate:mysql": "prisma migrate dev --schema=prisma/schema.mysql.prisma",
    "db:studio:postgres": "prisma studio --schema=prisma/schema.postgres.prisma",
    "db:studio:mysql": "prisma studio --schema=prisma/schema.mysql.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.postgres.prisma && prisma generate --schema=prisma/schema.mysql.prisma",
    "docker:postgres": "docker compose up postgres -d",
    "docker:mysql": "docker compose up mysql -d",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamashua1/mini-bank-.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hamashua1/mini-bank-/issues"
  },
  "homepage": "https://github.com/hamashua1/mini-bank-#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/server": "^13.3.0",
    "@simplewebauthn/types": "^12.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "ngrok": "^5.0.0-beta.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
